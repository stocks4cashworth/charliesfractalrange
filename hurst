/**
 * Calculates daily rolling Hurst Exponents and Volatility Ranges 
 * over multiple time horizons (7, 14, 21, 30, 60, 90 days).
 * Header row is row 2; data starts on row 3.
 * Results are batch-written starting at Column I.
 */
function generateDailyRollingFractalMatrix() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Sheet1");
  
  if (!sheet) {
    SpreadsheetApp.getUi().alert("Error: 'Sheet1' not found.");
    return;
  }
  
  var lastRow = sheet.getLastRow();
  // Header is row 2, so we need at least one row of data on row 3
  if (lastRow <= 2) {
    SpreadsheetApp.getUi().alert("Error: Not enough data in Sheet1 to process.");
    return;
  }
  
  // 1. Fetch raw data columns starting from Row 3 down
  var totalRows = lastRow - 2; // Exclude row 1 and row 2 header
  var allCloses = sheet.getRange(3, 5, totalRows, 1).getValues().flat();      // Col E
  var priceReturns = sheet.getRange(3, 7, totalRows, 1).getValues().flat();   // Col G
  var volumeReturns = sheet.getRange(3, 8, totalRows, 1).getValues().flat();  // Col H
  
  // Define our Master Tracking Horizons
  var timeframes = [10, 15, 20, 30, 60, 90];
  
  // Sub-window divisors used to compute a true linear regression slope for Hurst
  var subWindowDivisors = [1.0, 0.5, 0.25]; 

  // Setup Headers for the Output Columns (6 metrics per timeframe * 6 timeframes = 36 columns wide)
  var headers = [];
  timeframes.forEach(function(n) {
    headers.push(
      n + "d Price Hurst", 
      n + "d Vol Hurst", 
      n + "d Scaling Factor", 
      n + "d Volatility (σ)", 
      n + "d Upper Range", 
      n + "d Lower Range"
    );
  });
  
  var outputGrid = [];
  
  // 2. Core Execution Loop: Process every single historical data row sequentially
  for (var i = 0; i < totalRows; i++) {
    var rowData = [];
    var latestClose = allCloses[i];
    
    // Process each timeframe independently for the current row
    for (var t = 0; t < timeframes.length; t++) {
      var n = timeframes[t];
      
      // Lookback guard check: do we have enough historical data points prior to this row index?
      if (i + 1 < n) {
        // Pad with empty entries if history isn't deep enough yet
        rowData.push("", "", "", "", "", "");
        continue;
      }
      
      // Slice tracking windows trailing back from the current day 'i'
      var subPriceReturns = priceReturns.slice(i - n + 1, i + 1);
      var subVolReturns = volumeReturns.slice(i - n + 1, i + 1);
      
      // --- RIGOROUS REGRESSION-BASED HURST ESTIMATION ---
      var priceHurst = calculateRegressionHurst(subPriceReturns, n, subWindowDivisors);
      var volHurst = calculateRegressionHurst(subVolReturns, n, subWindowDivisors);
      
      // --- DYNAMIC SCALING FACTOR MATRIX ---
      var scalingFactor = 0.5;
      if (priceHurst >= 0.50) {
        scalingFactor = (volHurst >= 0.50) ? (priceHurst * (1 + volHurst)) : (priceHurst * (1 - volHurst));
      } else {
        scalingFactor = priceHurst * volHurst;
      }
      
      // --- VOLATILITY DISPERSION & RISK RANGES ---
      var periodVolatility = calculateSampleStDev(subPriceReturns);
      var dispersionBuffer = latestClose * (periodVolatility * scalingFactor * Math.sqrt(n));
      
      var upperFractalRange = latestClose + dispersionBuffer;
      var lowerFractalRange = latestClose - dispersionBuffer;
      
      // Push calculations into row data array matching headers order
      rowData.push(priceHurst, volHurst, scalingFactor, periodVolatility, upperFractalRange, lowerFractalRange);
    }
    outputGrid.push(rowData);
  }
  
  // 3. Clean up old structures and batch-write output data starting on Column I (Column 9)
  var startColumn = 9;
  var numOutputCols = headers.length;
  
  // Clear any existing calculations in the target destination zone (starting from header row 2 down)
  sheet.getRange(2, startColumn, sheet.getLastRow() - 1, numOutputCols).clearContent();
  
  // Write fresh metadata headers to Row 2
  sheet.getRange(2, startColumn, 1, numOutputCols).setValues([headers]).setFontWeight("bold").setBackground("#f3f3f3");
  
  // Write the comprehensive historical tracking grid starting at Row 3
  sheet.getRange(3, startColumn, outputGrid.length, numOutputCols).setValues(outputGrid);
  
  //SpreadsheetApp.getUi().alert("Success! Historical Daily Rolling Hurst & Fractal Matrix generated across all horizons.");
}

/**
 * HELPER: Calculates the mathematically correct Hurst Exponent using Linear Regression
 * over structured sub-window divisions to calculate log-scaling properties.
 */
function calculateRegressionHurst(series, macroWindow, divisors) {
  var logN_coords = [];
  var logRS_coords = [];
  
  for (var d = 0; d < divisors.length; d++) {
    var subSize = Math.floor(macroWindow * divisors[d]);
    if (subSize < 2) continue; // Changed from 4 to 2 to allow 7-day windows to scale
    
    var rsValues = [];
    // Slide across the series to find rolling R/S profiles for this sub-window size
    for (var start = 0; start <= series.length - subSize; start++) {
      var windowSlice = series.slice(start, start + subSize);
      var rs = computeSingleRSMetric(windowSlice);
      if (rs !== null && rs > 0) {
        rsValues.push(rs);
      }
    }
    
    if (rsValues.length > 0) {
      var avgRS = rsValues.reduce((a, b) => a + b, 0) / rsValues.length;
      logN_coords.push(Math.log10(subSize));
      logRS_coords.push(Math.log10(avgRS));
    }
  }
  
  // If we can't extract sufficient scaling points, default back to neutral random walk assumptions
  if (logN_coords.length < 2) return 0.5;
  
  // Return the Slope (m) of the linear regression line across our log coordinates
  return linearRegressionSlope(logN_coords, logRS_coords);
}

/**
 * HELPER: Calculates the traditional Rescaled Range (R/S) for an isolated series slice
 */
function computeSingleRSMetric(series) {
  var n = series.length;
  if (n === 0) return null;
  
  var mean = series.reduce((a, b) => a + b, 0) / n;
  var cumDev = 0, maxDev = 0, minDev = 0, sumSqDist = 0;
  
  for (var j = 0; j < n; j++) {
    var dev = series[j] - mean;
    cumDev += dev;
    if (cumDev > maxDev) maxDev = cumDev;
    if (cumDev < minDev) minDev = cumDev;
    sumSqDist += Math.pow(dev, 2);
  }
  
  var range = maxDev - minDev;
  var stDev = Math.sqrt(sumSqDist / (n - 1)); // Sample standard deviation
  
  return (stDev > 0) ? (range / stDev) : null;
}

/**
 * HELPER: Computes sample standard deviation
 */
function calculateSampleStDev(array) {
  var n = array.length;
  if (n <= 1) return 0;
  var mean = array.reduce((a, b) => a + b, 0) / n;
  var sumSqDist = array.reduce((sum, val) => sum + Math.pow(val - mean, 2), 0);
  var variance = sumSqDist / (n - 1);
  return variance > 0 ? Math.sqrt(variance) : 0;
}

/**
 * HELPER: Simple Ordinary Least Squares (OLS) Linear Regression Slope calculator
 */
function linearRegressionSlope(x, y) {
  var n = x.length;
  var sumX = x.reduce((a, b) => a + b, 0);
  var sumY = y.reduce((a, b) => a + b, 0);
  
  var sumXY = 0, sumXX = 0;
  for (var i = 0; i < n; i++) {
    sumXY += (x[i] * y[i]);
    sumXX += (x[i] * x[i]);
  }
  
  var num = (n * sumXY) - (sumX * sumY);
  var den = (n * sumXX) - (sumX * sumX);
  
  if (den === 0) return 0.5; // Return flat distribution if division-by-zero risk manifests
  var slope = num / den;
  
  // Soft boundary constraints to filter out noise anomalies
  return Math.max(0.0, Math.min(1.0, slope));
}
