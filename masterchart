function createUnifiedChart() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  
  // 1. Separate our Source and Target sheets
  var sourceSheet = ss.getSheetByName("Sheet1"); // Read from here
  var targetSheet = ss.getSheetByName("Sheet2"); // Write data and chart here
  
  // Check if Sheet2 exists to prevent crashes
  if (!targetSheet) {
    Logger.log("Error: Sheet2 does not exist. Please create it first.");
    return;
  }
  
  // 2. Clear previous chart from Sheet2
  var charts = targetSheet.getCharts();
  for (var i = 0; i < charts.length; i++) {
    if (charts[i].getOptions().get('title') === 'Price & Hurst Projection') {
      targetSheet.removeChart(charts[i]);
    }
  }
  
  // 3. Extract Historical Data from Sheet1
  var lastRow = sourceSheet.getLastRow();
  if (lastRow < 21) return;
  
  var histDates = sourceSheet.getRange(21, 1, lastRow - 21 + 1, 1).getValues().flat();
  var histPrices = sourceSheet.getRange(21, 5, lastRow - 21 + 1, 1).getValues().flat();
  var lastActualDate = new Date(histDates[histDates.length - 1]);

  // 4. Extract Projections & Lookbacks from Sheet1
  var lookbacks = sourceSheet.getRange("A6:A13").getValues().flat().filter(Number);
  
  // ADJUST THESE to where your 3 projection columns are on Sheet1
  var proj1Raw = sourceSheet.getRange("h6:h13").getValues().flat();
  var proj2Raw = sourceSheet.getRange("i6:i13").getValues().flat();
  var proj3Raw = sourceSheet.getRange("j6:j13").getValues().flat();

  // 5. Extract Hurst Range Scale metrics from Sheet1
  var hurstMin = sourceSheet.getRange("j6:j12").getValues().flat();
  var hurstMax = sourceSheet.getRange("I6:i12").getValues().flat(); 
  var maxrange = Math.max(hurstMax);
  var minrange = Math.min(hurstMin);


  // 6. Build Combined Data Array
  var combinedData = [["Date", "Historical Price", "Proj High", "Proj Mid", "Proj Low"]];
  
  for (var j = 0; j < histDates.length; j++) {
    if (j === 0 && typeof histPrices[j] === 'string') continue; 
    combinedData.push([histDates[j], histPrices[j], null, null, null]);
  }
  
  var lastHistPrice = histPrices[histPrices.length - 1];
  combinedData.push([lastActualDate, lastHistPrice, lastHistPrice, lastHistPrice, lastHistPrice]);

  for (var k = 0; k < lookbacks.length; k++) {
    var projectedDate = new Date(lastActualDate);
    projectedDate.setDate(projectedDate.getDate() + lookbacks[k]);
    combinedData.push([projectedDate, null, proj1Raw[k], proj2Raw[k], proj3Raw[k]]);
  }

  // 7. Write Data Table to Sheet2 (Using Row 1 as a clean workspace, or change to 100)
  var startRow = 1; 
  targetSheet.getRange(startRow, 1, targetSheet.getLastRow() + 1, 5).clearContent(); // wipe old table on Sheet2
  targetSheet.getRange(startRow, 1, combinedData.length, 5).setValues(combinedData);

  // 8. Define Chart Range using the new table on Sheet2
  var chartRange = targetSheet.getRange(startRow, 1, combinedData.length, 5);

  // 9. Generate and Insert Unified Chart onto Sheet2
  var chartBuilder = targetSheet.newChart()
    .setChartType(Charts.ChartType.LINE)
    .addRange(chartRange)
    .setPosition(15, 4, 0, 0) // Places at D15 on Sheet2
    .setOption('title', 'Price & Fractal Range Projection')
    .setOption('titleTextBoxStyle', { textStyle: { fontSize: 11, bold: true } })
    .setOption('legend', { position: 'bottom' })
    .setOption('useFirstRowAsHeaders', true)
    .setOption('interpolateNulls', true) 
    .setOption('vAxis', {
      viewWindow: {
        min: minrange * 0.95, 
        max: maxrange * 1.05  
      }
    });

  targetSheet.insertChart(chartBuilder.build());
}
