
function generateHurstranges() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var summarySheet = ss.getSheetByName("Hurst Summary");
  var sourceSheet = ss.getSheetByName("Sheet7");
  
  if (!summarySheet || !sourceSheet) {
    SpreadsheetApp.getUi().alert("Missing required sheets. Please run the matrix script first.");
    return;
  }
  
  // 1. Pull the computed Price AND Volume Hurst values from the Summary Sheet
  var nearPriceHurst = summarySheet.getRange("L6").getValue();
  var longPriceHurst = summarySheet.getRange("L7").getValue();
  var nearVolHurst = summarySheet.getRange("O6").getValue();
  var longVolHurst = summarySheet.getRange("O7").getValue();
  
  // Guard rails against invalid Hurst inputs
  if (isNaN(nearPriceHurst) || nearPriceHurst <= 0) nearPriceHurst = 0.5;
  if (isNaN(longPriceHurst) || longPriceHurst <= 0) longPriceHurst = 0.5;
  if (isNaN(nearVolHurst) || nearVolHurst <= 0) nearVolHurst = 0.5;
  if (isNaN(longVolHurst) || longVolHurst <= 0) longVolHurst = 0.5;
  
  // 2. Fetch ALL values in Column G (Price Returns) to find the true last row
  var lastRowRaw = sourceSheet.getLastRow();
  var allGValues = sourceSheet.getRange(1, 7, lastRowRaw, 1).getValues().map(r => r[0]);
  
  var trueLastRowIndex = lastRowRaw;
  for (var k = lastRowRaw - 1; k >= 0; k--) {
    if (allGValues[k] !== "" && !isNaN(allGValues[k]) && allGValues[k] !== null) {
      trueLastRowIndex = k + 1;
      break;
    }
  }
  
  var latestClose = sourceSheet.getRange(trueLastRowIndex, 5).getValue(); // Column E
  
  // Pull all raw closing prices from Column E (Index 5) up to true last row
  var allClosePrices = sourceSheet.getRange(1, 5, trueLastRowIndex, 1).getValues().map(r => r[0]);
  
  // 3. Build filtered arrays of pure numeric trailing log returns
  var validLogReturns = allGValues.slice(0, trueLastRowIndex).filter(function(val) {
    return val !== "" && !isNaN(val) && val !== null;
  });
  
  if (validLogReturns.length < 120) {
    SpreadsheetApp.getUi().alert("Not enough historical data rows (need 120 rows) to map the macro standard deviation ranges.");
    return;
  }
  
  // 4. Calculate exact matching Sample Standard Deviations for every single horizon
  var stDev7   = calculateStDev(validLogReturns.slice(-7));
  var stDev14  = calculateStDev(validLogReturns.slice(-14));
  var stDev21  = calculateStDev(validLogReturns.slice(-21));
  var stDev28  = calculateStDev(validLogReturns.slice(-28));
  var stDev90  = calculateStDev(validLogReturns.slice(-90));
  var stDev120 = calculateStDev(validLogReturns.slice(-120));
  
  // Average the standard deviations to match matrix slope groups
  var avgNearStDev = (stDev7 + stDev14 + stDev21) / 3;
  var avgLongStDev = (stDev28 + stDev90 + stDev120) / 3;
  
  // NEW: Calculate individual timeframe closing averages from Column E
  var avg7   = allClosePrices.slice(-7).reduce((a, b) => a + b, 0) / 7;
  var avg14  = allClosePrices.slice(-14).reduce((a, b) => a + b, 0) / 14;
  var avg21  = allClosePrices.slice(-21).reduce((a, b) => a + b, 0) / 21;
  var avg28  = allClosePrices.slice(-28).reduce((a, b) => a + b, 0) / 28;
  var avg90  = allClosePrices.slice(-90).reduce((a, b) => a + b, 0) / 90;
  var avg120 = allClosePrices.slice(-120).reduce((a, b) => a + b, 0) / 120;
  
  // Blended period averages used to define directional trend health
  var blendedNearAvgClose = (avg7 + avg14 + avg21) / 3;
  var blendedLongAvgClose = (avg28 + avg90 + avg120) / 3;
  
  // 5. Generate Near-Term Metrics (7-day time scalar base using matched Near-Term volatility)
  var nearRegime = determineRegime(nearPriceHurst, latestClose, blendedNearAvgClose);
  var nearBuffer = latestClose * (avgNearStDev * nearPriceHurst * nearVolHurst * Math.sqrt(7));
  var nearUpper = latestClose + nearBuffer;
  var nearLower = latestClose - nearBuffer;
  
  // 6. Generate Long-Range Metrics (30-day time scalar base using matched Long-Range volatility)
  var longRegime = determineRegime(longPriceHurst, latestClose, blendedLongAvgClose);
  var longBuffer = latestClose * (avgLongStDev * longPriceHurst * longVolHurst * Math.sqrt(30));
  var longUpper = latestClose + longBuffer;
  var longLower = latestClose - longBuffer;
  
  // 7. Print Signals Table onto the Hurst Summary Sheet (Zoned in Columns Q & R)
  summarySheet.getRange("Q1:R1").setValues([["METRIC/SIGNAL", "TACTICAL VALUE"]]).setFontWeight("bold");
  
  var signalData = [
    ["Latest Anchor Close", latestClose],
    ["---", "---"],
    ["NEAR PRICE HURST", nearPriceHurst],
    ["NEAR VOLUME HURST", nearVolHurst],
    ["NEAR-TERM REGIME", nearRegime],
    ["Near-Term Period Baseline Avg", blendedNearAvgClose], // Added row
    ["Near-Term Upper Range", nearUpper],
    ["Near-Term Lower Range", nearLower],
    ["---", "---"],
    ["LONG PRICE HURST", longPriceHurst],
    ["LONG VOLUME HURST", longVolHurst],
    ["LONG-RANGE REGIME", longRegime],
    ["Long-Range Period Baseline Avg", blendedLongAvgClose], // Added row
    ["Long-Range Upper Range", longUpper],
    ["Long-Range Lower Range", longLower]
  ];
  
  summarySheet.getRange("Q2:R22").clearContent();
  summarySheet.getRange(2, 17, signalData.length, 2).setValues(signalData);
  
  // Format styling
  summarySheet.getRange("R7").setFontWeight("bold");
  summarySheet.getRange("R15").setFontWeight("bold");
}

// Helper Function: Regime Determination based on Period Averages
function determineRegime(hurst, currentClose, periodAverage) {
  if (hurst > 0.53) {
    return (currentClose >= periodAverage) ? "BULLISH BREAKOUT (Trend Follow)" : "BEARISH MARKDOWN (Trend Follow)";
  } else if (hurst < 0.47) {
    return "REVERTING CHOP (Fade Extremes)";
  } else {
    return "RANDOM WALK (Noise Box)";
  }
}

// Helper Function: Standard Deviation
function calculateStDev(array) {
  var n = array.length;
  if (n <= 1) return 0;
  var mean = array.reduce((a, b) => a + b, 0) / n;
  var sumSqDist = array.reduce((sum, val) => sum + Math.pow(val - mean, 2), 0);
  var variance = sumSqDist / (n - 1);
  return variance > 0 ? Math.sqrt(variance) : 0;
}
