function calculateHurstMatrix1() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sourceSheet = ss.getSheetByName("Sheet7"); 
  
  var lastRow = sourceSheet.getLastRow();
  
  // 1. Target Column G (Index 7) for Price Log Returns
  var logReturnsPrice = sourceSheet.getRange(2, 7, lastRow - 1, 1).getValues().map(function(row) {
    return row[0];
  }).filter(function(val) {
    return val !== "" && !isNaN(val);
  });
  
  // 2. Target Column H (Index 8) for Volume Log Returns
  var logReturnsVol = sourceSheet.getRange(2, 8, lastRow - 1, 1).getValues().map(function(row) {
    return row[0];
  }).filter(function(val) {
    return val !== "" && !isNaN(val);
  });
  
  var totalLength = logReturnsPrice.length;
  if (totalLength < 7) {
    SpreadsheetApp.getUi().alert("Not enough data in Sheet7 to process matrix calculations.");
    return;
  }

  // Define separate Near-Term and Long-Range window horizons
  var nearWindows = [7, 14, 21];
  var longWindows = [28, 90, 120];
  
  // Arrays to hold the log data blocks for printing
  var priceSummaryData = [["Window Size (n)", "Log10(n)", "Avg R/S (Price)", "Log10(Avg R/S Price)"]];
  var volSummaryData = [["Window Size (n)", "Log10(n)", "Avg R/S (Volume)", "Log10(Avg R/S Vol)"]];
  
  var nearRowsCount = 0;
  var longRowsCount = 0;

  // --- NEAR-TERM MATRIX LOOP ---
  for (var w = 0; w < nearWindows.length; w++) {
    var n = nearWindows[w];
    if (n > totalLength) continue;
    
    var rsPriceValues = [];
    var rsVolValues = [];
    
    for (var i = 0; i <= totalLength - n; i++) {
      var subSeriesPrice = logReturnsPrice.slice(i, i + n);
      var rsP = computeSingleRS(subSeriesPrice);
      if (rsP !== null) rsPriceValues.push(rsP);
      
      var subSeriesVol = logReturnsVol.slice(i, i + n);
      var rsV = computeSingleRS(subSeriesVol);
      if (rsV !== null) rsVolValues.push(rsV);
    }
    
    if (rsPriceValues.length > 0) {
      var avgRS_P = rsPriceValues.reduce(function(a, b) { return a + b; }, 0) / rsPriceValues.length;
      priceSummaryData.push([n, Math.log10(n), avgRS_P, Math.log10(avgRS_P)]);
      nearRowsCount++;
    }
    if (rsVolValues.length > 0) {
      var avgRS_V = rsVolValues.reduce(function(a, b) { return a + b; }, 0) / rsVolValues.length;
      volSummaryData.push([n, Math.log10(n), avgRS_V, Math.log10(avgRS_V)]);
    }
  }

  var longStartRow = priceSummaryData.length + 1;

  // --- LONG-RANGE MATRIX LOOP ---
  for (var w = 0; w < longWindows.length; w++) {
    var n = longWindows[w];
    if (n > totalLength) continue;
    
    var rsPriceValues = [];
    var rsVolValues = [];
    
    for (var i = 0; i <= totalLength - n; i++) {
      var subSeriesPrice = logReturnsPrice.slice(i, i + n);
      var rsP = computeSingleRS(subSeriesPrice);
      if (rsP !== null) rsPriceValues.push(rsP);
      
      var subSeriesVol = logReturnsVol.slice(i, i + n);
      var rsV = computeSingleRS(subSeriesVol);
      if (rsV !== null) rsVolValues.push(rsV);
    }
    
    if (rsPriceValues.length > 0) {
      var avgRS_P = rsPriceValues.reduce(function(a, b) { return a + b; }, 0) / rsPriceValues.length; 
      priceSummaryData.push([n, Math.log10(n), avgRS_P, Math.log10(avgRS_P)]);
      longRowsCount++;
    }
    if (rsVolValues.length > 0) {
      var avgRS_V = rsVolValues.reduce(function(a, b) { return a + b; }, 0) / rsVolValues.length;
      volSummaryData.push([n, Math.log10(n), avgRS_V, Math.log10(avgRS_V)]);
    }
  }
  
  // Calculate Whole Time Metrics
  var wholeTimePriceRS = computeSingleRS(logReturnsPrice);
  var wholeTimeVolRS = computeSingleRS(logReturnsVol);
  
  // --- OUTPUT GENERATION ---
  var outputSheet = ss.getSheetByName("Hurst Summary");
  if (!outputSheet) {
    outputSheet = ss.insertSheet("Hurst Summary");
  } else {
    // Only clear columns A through I to protect your signal tables
    outputSheet.getRange("A1:I50").clearContent();
  }
  
  // Paste Master Price Matrix (A-D)
  outputSheet.getRange(1, 1, priceSummaryData.length, 4).setValues(priceSummaryData);
  
  // Paste Master Volume Matrix (F-I)
  outputSheet.getRange(1, 6, volSummaryData.length, 4).setValues(volSummaryData);
  
  // --- PRICE METRICS COLUMN K ---
  outputSheet.getRange("K2").setValue("Whole Time Price Data Points (N):");
  outputSheet.getRange("L2").setValue(totalLength);
  outputSheet.getRange("K3").setValue("Whole Time Price R/S:");
  outputSheet.getRange("L3").setValue(wholeTimePriceRS);
  outputSheet.getRange("K4").setValue("Whole Time Price Hurst (H):");
  outputSheet.getRange("L4").setFormula("=LOG10(L3)/LOG10(L2)");
  
  var nearLastRow = 1 + nearRowsCount;
  outputSheet.getRange("K6").setValue("Near-Term Price Matrix Hurst (H):");
  outputSheet.getRange("L6").setFormula("=SLOPE(D2:D" + nearLastRow + ", B2:B" + nearLastRow + ")");
  
  var longLastRow = longStartRow + longRowsCount - 1;
  outputSheet.getRange("K7").setValue("Long-Range Price Matrix Hurst (H):");
  outputSheet.getRange("L7").setFormula("=SLOPE(D" + longStartRow + ":D" + longLastRow + ", B" + longStartRow + ":B" + longLastRow + ")");

  // --- VOLUME METRICS COLUMN N ---
  outputSheet.getRange("N2").setValue("Whole Time Volume Data Points (N):");
  outputSheet.getRange("O2").setValue(logReturnsVol.length);
  outputSheet.getRange("N3").setValue("Whole Time Volume R/S:");
  outputSheet.getRange("O3").setValue(wholeTimeVolRS);
  outputSheet.getRange("N4").setValue("Whole Time Volume Hurst (H):");
  outputSheet.getRange("O4").setFormula("=LOG10(O3)/LOG10(O2)");
  
  outputSheet.getRange("N6").setValue("Near-Term Volume Matrix Hurst (H):");
  outputSheet.getRange("O6").setFormula("=SLOPE(I2:I" + nearLastRow + ", G2:G" + nearLastRow + ")");
  
  outputSheet.getRange("N7").setValue("Long-Range Volume Matrix Hurst (H):");
  outputSheet.getRange("O7").setFormula("=SLOPE(I" + longStartRow + ":I" + longLastRow + ", G" + longStartRow + ":G" + longLastRow + ")");
  
  // Automatically pass variables down to generate the execution boxes
 // generateHurstSignals();
}

// RESTORED HELPER FUNCTION: Calculates R/S for a single discrete array of data
function computeSingleRS(series) {
  var n = series.length;
  if (n === 0) return null;
  var mean = series.reduce(function(a, b) { return a + b; }, 0) / n;
  
  var cumDev = 0;
  var maxDev = 0;
  var minDev = 0;
  var sumSqDist = 0;
  
  for (var j = 0; j < n; j++) {
    var dev = series[j] - mean;
    cumDev += dev;
    if (cumDev > maxDev) maxDev = cumDev;
    if (cumDev < minDev) minDev = cumDev;
    
    sumSqDist += Math.pow(dev, 2);
  }
  
  var range = maxDev - minDev;
  var stDev = Math.sqrt(sumSqDist / (n - 1)); // Sample stdev
  
  return (stDev > 0) ? (range / stDev) : null;
}
