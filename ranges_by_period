function calculateMasterFractalMatrix() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sourceSheet = ss.getSheetByName("Sheet1"); 
  var outputSheet = ss.getSheetByName("Sheet1");
  if (!sourceSheet) {
    SpreadsheetApp.getUi().alert("Error: Sheet7 not found.");
    return;
  }
  if (!outputSheet) {
    outputSheet = ss.insertSheet("Sheet1");
  }
  
  var lastRow = sourceSheet.getLastRow();
  if (lastRow <= 2) {
    SpreadsheetApp.getUi().alert("Error: Not enough rows in Sheet7 to process.");
    return;
  }
  
  // 1. Target exact column mappings from Sheet7
  var allCloses = sourceSheet.getRange(1, 5, lastRow, 1).getValues().map(function(r) { return r[0]; });
  var allPriceReturns = sourceSheet.getRange(1, 7, lastRow, 1).getValues().map(function(r) { return r[0]; });
  var allVolReturns = sourceSheet.getRange(1, 8, lastRow, 1).getValues().map(function(r) { return r[0]; });
  
  // Find the true last active row index with valid numbers in Column G
  var trueLastRowIndex = lastRow;
  for (var k = lastRow - 1; k >= 0; k--) {
    if (allPriceReturns[k] !== "" && !isNaN(allPriceReturns[k]) && allPriceReturns[k] !== null) {
      trueLastRowIndex = k + 1;
      break;
    }
  }
  
  var latestClose = allCloses[trueLastRowIndex - 1];
  
  // Filter out headers/non-numeric strings up to our true data end
  var validPriceReturns = allPriceReturns.slice(0, trueLastRowIndex).filter(function(v) { return v !== "" && !isNaN(v) && !isNaN(parseFloat(v)) && v !== null; });
  var validVolReturns = allVolReturns.slice(0, trueLastRowIndex).filter(function(v) { return v !== "" && !isNaN(v) && !isNaN(parseFloat(v)) && v !== null; });
  var validCloses = allCloses.slice(0, trueLastRowIndex).filter(function(v) { return v !== "" && !isNaN(v) && !isNaN(parseFloat(v)) && v !== null; });
  
  // Explicit 7 duration horizons
  var timeframes = [7,14,21,30,60,90];
  
  // Setup headers for the master dashboard output (12 Columns Wide)
  var matrixTable = [[
    "Lookback (n)", 
    "Price R/S",         
    "Price Hurst (Hp)", 
    "Volume R/S",        
    "Volume Hurst (Hv)", 
    "Scaling Factor (SF)",
    "Volatility (σ)",
    "Period Mean Price", 
    "Upper Fractal Range",
    "Lower Fractal Range",
    "Signal Regime",
    "Range Position / Tracker" 
  ]];
  
  var rowsAdded = 0;
  
  // 2. Compute metrics independently for every single period
  for (var t = 0; t < timeframes.length; t++) {
    var n = timeframes[t];
    if (n > validPriceReturns.length || n > validVolReturns.length || n > validCloses.length) continue;
    
    // Slice clean trailing arrays matching the current lookback duration
    var subPriceReturns = validPriceReturns.slice(-n);
    var subVolReturns = validVolReturns.slice(-n);
    var subCloses = validCloses.slice(-n);
    
    // Compute Rescaled Ranges
    var priceRS = computeSingleRS(subPriceReturns);
    var volRS = computeSingleRS(subVolReturns);
    
    // Compute explicit Hurst Exponents
    var priceHurst = (priceRS > 0) ? (Math.log10(priceRS) / Math.log10(n)) : 0.5;
    var volHurst = (volRS > 0) ? (Math.log10(volRS) / Math.log10(n)) : 0.5;
    
    // Dynamic Scaling Factor (SF) Matrix Logic
    var scalingFactor = 0.5;
    if (priceHurst >= 0.50) {
      scalingFactor = (volHurst >= 0.50) ? (priceHurst * (1 + volHurst)) : (priceHurst * (1 - volHurst));
    } else {
      scalingFactor = priceHurst * volHurst;
    }
    
    // Compute percentage volatility dispersion
    var periodVolatility = calculateStDev(subPriceReturns);
    
    // Compute baseline mean price over lookback window
    var periodMeanPrice = subCloses.reduce(function(a, b) { return a + b; }, 0) / n;
    
    // Calculate the Volatility Dispersion Buffer
    var dispersionBuffer = latestClose * (periodVolatility * scalingFactor * Math.sqrt(n));
    var upperFractalRange = latestClose + dispersionBuffer;
    var lowerFractalRange = latestClose - dispersionBuffer;
    
    // Determine the Signal Regime based on price position vs. timeframe average
    var regime = "RANDOM WALK (Noise)";
    if (priceHurst > 0.53) {
      regime = (latestClose >= periodMeanPrice) ? "BULLISH BREAKOUT" : "BEARISH MARKDOWN";
    } else if (priceHurst < 0.47) {
      regime = "REVERTING CHOP (Fade)";
    }
    
    // Row math: headers on row 5, first data row is 6
    var currentRowNum = 6 + rowsAdded;
    
    // Dynamically build the tracker formula targeting current row dimensions
    var trackerFormula = '=IFS(' +
      '$B$2 > I' + currentRowNum + ', "above range", ' +
      '$B$2 < J' + currentRowNum + ', "below range", ' +
      '$B$2 <= I' + currentRowNum + ', SPARKLINE({J' + currentRowNum + '-$B$2, (I' + currentRowNum + '-J' + currentRowNum + ')*0.05}, {"charttype","bar"; "max",I' + currentRowNum + '-J' + currentRowNum + '; "color1","white"; "color2",IFS($B$2 > H' + currentRowNum + ',"green",$B$2 < H' + currentRowNum + ',"red",$B$2 = H' + currentRowNum + ',"purple")})' +
    ')';

    // Pack data row in exact matching order to headers
    matrixTable.push([
      n, 
      priceRS,
      priceHurst, 
      volRS,
      volHurst, 
      scalingFactor,
      periodVolatility, 
      periodMeanPrice, 
      upperFractalRange,
      lowerFractalRange,
      regime,
      trackerFormula 
    ]);
    rowsAdded++;
  }
  
  // 3. Clean and reprint the summary layout perfectly
  //outputSheet.clearContent(); 
  outputSheet.clearConditionalFormatRules(); 
  
  // Write the foundational info block at the top
  outputSheet.getRange("A1").setValue("MULTI-DURATION FRACTAL RISK RANGES").setFontWeight("bold");
  outputSheet.getRange("A2").setValue("Latest Anchor Close:");
  outputSheet.getRange("B2").setValue(latestClose).setFontWeight("bold");
  
  // Paste our master metrics table starting on row 5 (now expanded to 12 columns wide)
  outputSheet.getRange(5, 1, matrixTable.length, 12).setValues(matrixTable);
  outputSheet.getRange(5, 1, 1, 12).setFontWeight("bold").setBackground("#f3f3f3");
  
  // Format price columns cleanly as currency
  if (rowsAdded > 0) {
    outputSheet.getRange(6, 8, rowsAdded, 3).setNumberFormat("$#,##0.00");
    
    // Apply the custom Hurst conditional formatting rules natively using the internal helper
    applyMatrixHurstFormatting(outputSheet, rowsAdded);
    generateFractalRangeChart();
  }
  
  //SpreadsheetApp.getUi().alert("Master Matrix fully updated with Rescaled Ranges and Fractal Boundaries!");
}

/**
 * INTERNAL HELPER: Strictly maps formatting to Column C (Price Hurst) 
 * and Column E (Volume Hurst) dynamically for Sheet8
 */
function applyMatrixHurstFormatting(sheet) {
  var priceHurstRange = sheet.getRange(6, 3, 7, 1);
  var volumeHurstRange = sheet.getRange(6, 5, 7, 1);
  var targetRanges = [priceHurstRange, volumeHurstRange];
  
  var rules = sheet.getConditionalFormatRules();
  
  var tiers = [
    { min: 0.60, max: 1.00, bg: "#D9C3F0", font: "#1f1f1f" }, 
    { min: 0.53, max: 0.60, bg: "#EFE5F9", font: "#1f1f1f" }, 
    { min: 0.47, max: 0.53, bg: "#E0E0E0", font: "#1f1f1f" }, 
    { min: 0.40, max: 0.47, bg: "#FFE0B2", font: "#1f1f1f" }, 
    { min: 0.00, max: 0.40, bg: "#FFCC80", font: "#1f1f1f" }  
  ];
  
  tiers.forEach(function(tier) {
    var rule = SpreadsheetApp.newConditionalFormatRule()
      .whenNumberBetween(tier.min, tier.max)
      .setBackground(tier.bg)
      .setFontColor(tier.font)
      .setRanges(targetRanges)
      .build();
    rules.push(rule);
  });
  
  sheet.setConditionalFormatRules(rules);

}

/**
 * INTERNAL HELPER: Compares H6:H12 against a static anchor in B2.
 * Above B2 = Red, Below B2 = Green.
 */
function applytrendFormatting(sheet) {
 var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  
  var rules =sheet.getConditionalFormatRules();
  
  // Target range is exactly H6:H12
  // getRange(startRow, startColumn, numRows, numColumns)
  var targetRange = sheet.getRange(6, 8, 7, 1); 
  
  // Define Soft Hex Colors
  var redBg     = "#FCE8E6"; 
  var redFont   = "#1f1f1f";
  var greenBg   = "#E6F4EA"; 
  var greenFont = "#1f1f1f";

  // RULE 1: Above Anchor (Red) -> If cell in H is greater than B2
  // We use $B$2 so it doesn't shift as it checks H6 through H12
  var ruleAbove = SpreadsheetApp.newConditionalFormatRule()
    .whenFormulaSatisfied("=H7<$B$2") 
    .setBackground(redBg)
    .setFontColor(redFont)
    .setRanges([targetRange])
    .build();
    
  // RULE 2: Below Anchor (Green) -> If cell in H is less than B2
  var ruleBelow = SpreadsheetApp.newConditionalFormatRule()
    .whenFormulaSatisfied("=H7>$B$2")
    .setBackground(greenBg)
    .setFontColor(greenFont)
    .setRanges([targetRange])
    .build();
    
  rules.push(ruleAbove, ruleBelow);
  sheet.setConditionalFormatRules(rules);

  SpreadsheetApp.getUi().alert("Master Matrix fully updated with Rescaled Ranges and Fractal Boundaries!");
}






// Helper Function: Rescaled Range (R/S) Engine
function computeSingleRS(series) {
  var n = series.length;
  if (n === 0) return 0;
  var mean = series.reduce(function(a, b) { return a + b; }, 0) / n;
  
  var cumDev = 0;
  var maxDev = 0;
  var minDev = 0;
  var sumSqDist = 0;
  for (var j = 0; j < n; j++) {
    var dev = series[j] - mean;
    cumDev += dev;
    if (cumDev > maxDev) maxDev = cumDev;
    if (cumDev < minDev) minDev = cumDev;
    sumSqDist += Math.pow(dev, 2);
  }
  
  var range = maxDev - minDev;
  var variance = sumSqDist / (n - 1);
  var stDev = variance > 0 ? Math.sqrt(variance) : 0;
  return (stDev > 0) ? (range / stDev) : 0;
}

// Helper Function: Sample Standard Deviation Engine
function calculateStDev(array) {
  var n = array.length;
  if (n <= 1) return 0;
  var mean = array.reduce(function(a, b) { return a + b; }, 0) / n;
  var sumSqDist = array.reduce(function(sum, val) { return sum + Math.pow(val - mean, 2); }, 0);
  var variance = sumSqDist / (n - 1);
  return variance > 0 ? Math.sqrt(variance) : 0;
}







/**
 * Generates an embedded line chart for multi-duration fractal risk ranges on Sheet8.
 * X-axis: Lookback periods (A6:A12)
 * Y-axis: Mean (Blue), Upper (Green), Lower (Red), restricted to +/-10% of anchor close in B2.
 */
function generateFractalRangeChart() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Sheet1");
  
  if (!sheet) {
    SpreadsheetApp.getUi().alert("Error: 'Sheet8' not found.");
    return;
  }
  
  // 1. Fetch the latest anchor price from cell B2 to configure the vertical axis focus
  var latestClose = sheet.getRange("B2").getValue();
  if (!latestClose || isNaN(latestClose)) {
    SpreadsheetApp.getUi().alert("Error: Could not locate a valid Latest Anchor Close price in cell B2.");
    return;
  }
  
  // 2. Define Chart Data Sources
  // Domain (X-Axis): Lookback periods from A6 to A12
  var domainRange = sheet.getRange("A6:A12");
  // Series (Y-Axis): Columns H (Mean), I (Upper), J (Lower) from row 6 to 12
  var seriesRange = sheet.getRange("H6:J12");
  
  // 3. Clear any preexisting fractal risk charts to prevent stacking duplicate visuals
  var charts = sheet.getCharts();
  for (var c = 0; c < charts.length; c++) {
    if (charts[c].getOptions().get('title') === "Fractal Risk Ranges vs. Lookback Horizons") {
      sheet.removeChart(charts[c]);
    }
  }
  
  // 4. Compute the vertical axis boundaries (+/-10% of the anchor price)
  // 1. Get the values from the ranges (returns a 2D array like [[val1], [val2]])
  var jValues = sheet.getRange("J6:J13").getValues().flat();
  var iValues = sheet.getRange("I6:I13").getValues().flat();
  
  // 2. Use Math.min and Math.max with the spread operator (...)
  var vAxisMin = Math.min(...jValues);
  var vAxisMax = Math.max(...iValues);
  
  Logger.log("Min: " + vAxisMin);
  Logger.log("Max: " + vAxisMax);


  // 5. Build the Chart and customize series colors
  // Series indexing:
  // Series 0 (Column H) = Period Mean Price -> Blue (#0000FF)
  // Series 1 (Column I) = Upper Fractal Range -> Green (#008000)
  // Series 2 (Column J) = Lower Fractal Range -> Red (#FF0000)
  var chartBuilder = sheet.newChart()
    .setChartType(Charts.ChartType.LINE)
    .addRange(domainRange)
    .addRange(seriesRange)
    .setPosition(1, 14, 10, 5) // Places chart on row 6, column L (next to your data matrix)
    .setOption('title', 'Fractal Risk Ranges vs. Lookback Horizons')
    //.setOption('curveType', 'function') // Smooths lines cleanly across horizons
    .setOption('width', 500)
    .setOption('height', 300)
    .setOption('hAxis', {
      title: 'Lookback Window Size (n)',
      type: 'category' 
    })
    .setOption('vAxis', {
      title: 'Price ($)',
      minValue: vAxisMin,
      maxValue: vAxisMax,
      format: '$#,##0.00'
    })
    .setOption('colors', ['#0000FF', '#008000', '#FF0000']) // [Mean (Blue), Upper (Green), Lower (Red)]
    .setOption('legend', { position: 'bottom' });
    
  sheet.insertChart(chartBuilder.build());
  createLineChart();
}






function createLineChart() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Sheet1"); 
  
  var lastRow = sheet.getLastRow();
  if (lastRow < 21) {
    Logger.log("Not enough data to create a chart.");
    return;
  }
  
  // 1. Clear any previous versions of this chart to keep the sheet clean
  var charts = sheet.getCharts();
  for (var i = 0; i < charts.length; i++) {
    var chartOptions = charts[i].getOptions();
    var existingTitle = chartOptions.get('title');
    
    // Check for our new title or the previous placeholder title
    if (existingTitle === 'Price over Time' || existingTitle === 'Data Trend Over Time') {
      sheet.removeChart(charts[i]);
    }
  }
  
  // 2. Define the ranges
  var dateRange = sheet.getRange(21, 1, lastRow - 21 + 1, 1); // Column A
  var dataRange = sheet.getRange(21, 5, lastRow - 21 + 1, 1); // Column E
  
  // 3. Get data numbers to calculate Min/Max
  var dataValues = sheet.getRange(22, 5, lastRow - 22 + 1, 1).getValues().flat();
  var numericValues = dataValues.filter(function(val) {
    return typeof val === 'number' && !isNaN(val);
  });

  var dataMin = Math.min(...numericValues);
  var dataMax = Math.max(...numericValues);
  
  var paddingPercent = 0.10; 
  var rangeSpread = dataMax - dataMin;
  
  var yAxisMin = dataMin - (rangeSpread * paddingPercent);
  var yAxisMax = dataMax + (rangeSpread * paddingPercent);
  
  // 4. Build the Line Chart with smaller title styling
  var chartBuilder = sheet.newChart()
    .setChartType(Charts.ChartType.LINE)
    .addRange(dateRange) 
    .addRange(dataRange) 
    .setPosition(15, 4, 0, 0) // Places at D15
    .setOption('title', 'Price over Time')
    // Make the title font smaller (default is usually 14 or 16)
    .setOption('titleTextBoxStyle', {
      textStyle: {
        fontSize: 11,
        bold: true
      }
    })
    .setOption('legend', {position: 'bottom'})
    .setOption('useFirstRowAsHeaders', true)
    .setOption('vAxis', {
      viewWindow: {
        min: yAxisMin,
        max: yAxisMax
      }
    });
    
  // 5. Insert the fresh chart
  sheet.insertChart(chartBuilder.build());
}
