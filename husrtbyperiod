function calculateMasterFractalMatrix() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sourceSheet = ss.getSheetByName("Sheet7"); 
  var outputSheet = ss.getSheetByName("Hurst Summary");
  
  if (!sourceSheet) {
    SpreadsheetApp.getUi().alert("Error: Sheet7 not found.");
    return;
  }
  if (!outputSheet) {
    outputSheet = ss.insertSheet("Hurst Summary");
  }
  
  var lastRow = sourceSheet.getLastRow();
  if (lastRow <= 2) {
    SpreadsheetApp.getUi().alert("Error: Not enough rows in Sheet7 to process.");
    return;
  }
  
  // 1. Target exact column mappings from Sheet7
  var allCloses = sourceSheet.getRange(1, 5, lastRow, 1).getValues().map(function(r) { return r[0]; });
  var allPriceReturns = sourceSheet.getRange(1, 7, lastRow, 1).getValues().map(function(r) { return r[0]; });
  var allVolReturns = sourceSheet.getRange(1, 8, lastRow, 1).getValues().map(function(r) { return r[0]; });
  
  // Find the true last active row index with valid numbers in Column G
  var trueLastRowIndex = lastRow;
  for (var k = lastRow - 1; k >= 0; k--) {
    if (allPriceReturns[k] !== "" && !isNaN(allPriceReturns[k]) && allPriceReturns[k] !== null) {
      trueLastRowIndex = k + 1;
      break;
    }
  }
  
  var latestClose = allCloses[trueLastRowIndex - 1];
  
  // Filter out headers/non-numeric strings up to our true data end
  var validPriceReturns = allPriceReturns.slice(0, trueLastRowIndex).filter(function(v) { return v !== "" && !isNaN(v) && !isNaN(parseFloat(v)) && v !== null; });
  var validVolReturns = allVolReturns.slice(0, trueLastRowIndex).filter(function(v) { return v !== "" && !isNaN(v) && !isNaN(parseFloat(v)) && v !== null; });
  var validCloses = allCloses.slice(0, trueLastRowIndex).filter(function(v) { return v !== "" && !isNaN(v) && !isNaN(parseFloat(v)) && v !== null; });

  // Explicit 7 duration horizons
  var timeframes = [7, 14, 21, 30, 60, 90, 120];
  
  // Setup headers for the master dashboard output
  var matrixTable = [[
    "Lookback (n)", 
    "Price R/S",         // Added column
    "Price Hurst (Hp)", 
    "Volume R/S",        // Added column
    "Volume Hurst (Hv)", 
    "Scaling Factor (SF)",
    "Volatility (σ)",
    "Period Mean Price", 
    "Upper Fractal Range",
    "Lower Fractal Range",
    "Signal Regime"
  ]];
  
  var rowsAdded = 0;
  
  // 2. Compute metrics independently for every single period
  for (var t = 0; t < timeframes.length; t++) {
    var n = timeframes[t];
    if (n > validPriceReturns.length || n > validVolReturns.length || n > validCloses.length) continue; 
    
    // Slice clean trailing arrays matching the current lookback duration
    var subPriceReturns = validPriceReturns.slice(-n);
    var subVolReturns = validVolReturns.slice(-n);
    var subCloses = validCloses.slice(-n);
    
    // Compute Rescaled Ranges
    var priceRS = computeSingleRS(subPriceReturns);
    var volRS = computeSingleRS(subVolReturns);
    
    // Compute explicit Hurst Exponents
    var priceHurst = (priceRS > 0) ? (Math.log10(priceRS) / Math.log10(n)) : 0.5;
    var volHurst = (volRS > 0) ? (Math.log10(volRS) / Math.log10(n)) : 0.5;
    
    // Dynamic Scaling Factor (SF) Matrix Logic
    var scalingFactor = 0.5;
    if (priceHurst >= 0.50) {
      scalingFactor = (volHurst >= 0.50) ? (priceHurst * (1 + volHurst)) : (priceHurst * (1 - volHurst));
    } else {
      scalingFactor = priceHurst * volHurst;
    }
    
    // Compute percentage volatility dispersion
    var periodVolatility = calculateStDev(subPriceReturns);
    
    // Compute baseline mean price over lookback window
    var periodMeanPrice = subCloses.reduce(function(a, b) { return a + b; }, 0) / n;
    
    // Calculate the Volatility Dispersion Buffer
    var dispersionBuffer = latestClose * (periodVolatility * scalingFactor * Math.sqrt(n));
    var upperFractalRange = latestClose + dispersionBuffer;
    var lowerFractalRange = latestClose - dispersionBuffer;
    
    // Determine the Signal Regime based on price position vs. timeframe average
    var regime = "RANDOM WALK (Noise)";
    if (priceHurst > 0.53) {
      regime = (latestClose >= periodMeanPrice) ? "BULLISH BREAKOUT" : "BEARISH MARKDOWN";
    } else if (priceHurst < 0.47) {
      regime = "REVERTING CHOP (Fade)";
    }
    
    // Pack data row in exact matching order to headers
    matrixTable.push([
      n, 
      priceRS,
      priceHurst, 
      volRS,
      volHurst, 
      scalingFactor,
      periodVolatility, 
      periodMeanPrice, 
      upperFractalRange,
      lowerFractalRange,
      regime
    ]);
    rowsAdded++;
  }
  
  // 3. Clean and reprint the summary layout perfectly
  //outputSheet.clear();
  
  // Write the foundational info block at the top
  outputSheet.getRange("A20").setValue("MULTI-DURATION FRACTAL RISK RANGES").setFontWeight("bold");
  outputSheet.getRange("A21").setValue("Latest Anchor Close:");
  outputSheet.getRange("B20").setValue(latestClose).setFontWeight("bold");
  
  // Paste our master metrics table starting on row 5
  outputSheet.getRange(22, 1, matrixTable.length, 11).setValues(matrixTable);
  outputSheet.getRange(22, 1, 1, 11).setFontWeight("bold").setBackground("#f3f3f3");
  
  // Format price columns cleanly as currency (Mean Price, Upper Range, Lower Range move to columns 8, 9, 10)
  if (rowsAdded > 0) {
    outputSheet.getRange(6, 8, rowsAdded, 3).setNumberFormat("$#,##0.00");
  }
  
  SpreadsheetApp.getUi().alert("Master Matrix fully updated with Rescaled Ranges and Fractal Boundaries!");
}

// Helper Function: Rescaled Range (R/S) Engine
function computeSingleRS(series) {
  var n = series.length;
  if (n === 0) return 0;
  var mean = series.reduce(function(a, b) { return a + b; }, 0) / n;
  
  var cumDev = 0;
  var maxDev = 0;
  var minDev = 0;
  var sumSqDist = 0;
  
  for (var j = 0; j < n; j++) {
    var dev = series[j] - mean;
    cumDev += dev;
    if (cumDev > maxDev) maxDev = cumDev;
    if (cumDev < minDev) minDev = cumDev;
    
    sumSqDist += Math.pow(dev, 2);
  }
  
  var range = maxDev - minDev;
  var variance = sumSqDist / (n - 1);
  var stDev = variance > 0 ? Math.sqrt(variance) : 0;
  
  return (stDev > 0) ? (range / stDev) : 0;
}

// Helper Function: Sample Standard Deviation Engine
function calculateStDev(array) {
  var n = array.length;
  if (n <= 1) return 0;
  var mean = array.reduce(function(a, b) { return a + b; }, 0) / n;
  var sumSqDist = array.reduce(function(sum, val) { return sum + Math.pow(val - mean, 2); }, 0);
  var variance = sumSqDist / (n - 1);
  return variance > 0 ? Math.sqrt(variance) : 0;
}
